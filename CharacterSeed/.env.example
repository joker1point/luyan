# ============================================
# LLM Provider Selection (必填)
# 可选值: deepseek | qwen | zhipu | ollama | openai
# ============================================
LLM_PROVIDER=deepseek

# ============================================
# DeepSeek API Configuration
# ============================================
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============================================
# 通义千问 (Qwen) Configuration - 阿里云
# 获取 API Key: https://dashscope.console.aliyun.com/
# ============================================
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-turbo
# 可选模型: qwen-turbo, qwen-plus, qwen-max, qwen-long

# ============================================
# 智谱 GLM Configuration
# 获取 API Key: https://open.bigmodel.cn/
# ============================================
ZHIPU_API_KEY=your_zhipu_api_key_here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash
# 可选模型: glm-4-flash, glm-4, glm-4-plus

# ============================================
# Ollama (本地模型) Configuration
# 安装: https://ollama.ai/
# ============================================
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
# 可选模型: llama3, qwen2.5:7b, mistral, 等

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# 可选模型: gpt-4o, gpt-4o-mini, gpt-3.5-turbo

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=sqlite:///./data/character_seed.db

# ============================================
# Application Settings
# ============================================
DEBUG=True
API_V1_STR=/api